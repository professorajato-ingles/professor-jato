{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "level": { "type": "string", "enum": ["Iniciante", "Básico", "Intermediário", "Avançado", "untested"] },
        "currentModule": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "active": { "type": "boolean" }
      },
      "required": ["uid", "email", "level", "role"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message in a chat session",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model", "system"] },
        "content": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["role", "content", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": { "$ref": "#/entities/ChatMessage" },
      "description": "Chat history for a user"
    }
  }
}
